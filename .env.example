# Open-Meteo Configuration
# Copy this file to .env and fill in your actual values

# Optional: API key for paid tier (required for historical, ensemble, previous_runs, climate)
OPEN_METEO_API_KEY=your_api_key_here

# Optional: Location preset ('us_population_centers' or 'energy_hubs')
TAP_OPEN_MATEO_LOCATION_PRESETS=us_population_centers

# Optional: Temperature unit ('celsius' or 'fahrenheit', default: fahrenheit)
TAP_OPEN_MATEO_TEMPERATURE_UNIT=fahrenheit

# Optional: Wind speed unit ('kmh', 'ms', 'mph', 'kn', default: mph)
TAP_OPEN_MATEO_WIND_SPEED_UNIT=mph

# Optional: Precipitation unit ('mm' or 'inch', default: inch)
TAP_OPEN_MATEO_PRECIPITATION_UNIT=inch

# Optional: Timezone for daily aggregation (default: America/Chicago)
TAP_OPEN_MATEO_TIMEZONE=America/Chicago

# Optional: Historical start date (ISO format, e.g. 2020-01-01)
TAP_OPEN_MATEO_HISTORICAL_START_DATE=2020-01-01

# Optional: Forecast horizon in days (default: 16, max: 16)
TAP_OPEN_MATEO_FORECAST_DAYS=16

# Optional: Max API requests per minute (default: 500)
TAP_OPEN_MATEO_MAX_REQUESTS_PER_MINUTE=500

# Optional: Max locations per request batch (default: 10)
TAP_OPEN_MATEO_MAX_LOCATIONS_PER_REQUEST=10
